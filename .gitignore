# ══════════════════════════════════════════════════════════════
# Unified Supervised Learning AutoML Platform — .gitignore
# ══════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# ── Python Virtual Environments ───────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Python Testing ────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# ── Python Distribution / Packaging ──────────────────────────
dist/
build/
*.egg-info/
*.egg
*.whl
*.manifest
*.spec

# ── React / Vite / Node.js ───────────────────────────────────
node_modules/
dist/
build/
.vite/
*.tsbuildinfo

# ── Environment Files ────────────────────────────────────────
.env
.env.*
*.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Database Files ───────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── IDE / Editor Files ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Operating System Files ───────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
ehthumbs_vista.db
*.stackdump

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Temporary Files ──────────────────────────────────────────
temp/
tmp/
*.tmp
*.bak
*.swp
*.orig

# ── Uploaded Data / ML Artifacts (keep dirs via .gitkeep) ────
backend/data/platform.db
backend/app/data/uploads/*
!backend/app/data/uploads/.gitkeep
backend/app/data/models/*
!backend/app/data/models/.gitkeep
backend/app/data/reports/*
!backend/app/data/reports/.gitkeep

# ── Misc ─────────────────────────────────────────────────────
.cache/
*.pid
*.seed
*.pid.lock
